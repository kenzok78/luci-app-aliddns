#!/bin/sh

NAME="aliddns"
LOG_FILE="/var/log/${NAME}.log"

uci_get_by_name() {
	local ret
	ret="$(uci get "${NAME}.$1.$2" 2>/dev/null)"
	echo "${ret:-$3}"
}

uci_bool_by_name() {
	case "$(uci_get_by_name "$1" "$2")" in
		1 | on | true | yes | enabled) return 0 ;;
	esac
	return 1
}

intelnetip() {
	local tmp_ip
	tmp_ip="$(curl -sL --connect-timeout 3 members.3322.org/dyndns/getip 2>/dev/null)"
	if [ -z "$tmp_ip" ]; then
		tmp_ip="$(curl -sL --connect-timeout 3 api-ipv4.ip.sb/ip 2>/dev/null)"
	fi
	if [ -z "$tmp_ip" ]; then
		tmp_ip="$(curl -sL --connect-timeout 3 v4.myip.la 2>/dev/null)"
	fi
	if [ -z "$tmp_ip" ]; then
		tmp_ip="$(curl -sL --connect-timeout 3 whatismyip.akamai.com 2>/dev/null)"
	fi
	echo -n "$tmp_ip"
}

intelnetip6() {
	local tmp_ip6
	tmp_ip6="$(curl -sL --connect-timeout 3 ipv6.testipv6.cn/ip 2>/dev/null | sed 's+"+\n+g' | grep -oE '([0-9A-Fa-f]{0,4}:){2,7}[0-9A-Fa-f:]+' | grep ':' | head -n1)"
	if [ -z "$tmp_ip6" ]; then
		tmp_ip6="$(curl -sL --connect-timeout 3 ip6only.me/api 2>/dev/null | sed 's+,+\n+g' | grep -oE '([0-9A-Fa-f]{0,4}:){2,7}[0-9A-Fa-f:]+' | head -n1)"
	fi
	if [ -z "$tmp_ip6" ]; then
		tmp_ip6="$(curl -sL --connect-timeout 3 speed.neu6.edu.cn/getIP.php 2>/dev/null)"
	fi
	if [ -z "$tmp_ip6" ]; then
		tmp_ip6="$(curl -sL --connect-timeout 3 v6.ident.me 2>/dev/null)"
	fi
	if [ -z "$tmp_ip6" ]; then
		tmp_ip6="$(curl -sL --connect-timeout 3 api-ipv6.ip.sb/ip 2>/dev/null)"
	fi
	echo -n "$tmp_ip6"
}

resolve2ip() {
	local domain="$1"
	local tmp_ip
	tmp_ip="$(nslookup "$domain" ns1.alidns.com 2>/dev/null | sed '/^Server/d; /#53$/d' | grep -oE '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}' | tail -n1)"
	if [ -z "$tmp_ip" ]; then
		tmp_ip="$(nslookup "$domain" ns2.alidns.com 2>/dev/null | sed '/^Server/d; /#53$/d' | grep -oE '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}' | tail -n1)"
	fi
	if [ -z "$tmp_ip" ]; then
		tmp_ip="$(nslookup "$domain" 114.114.115.115 2>/dev/null | sed '/^Server/d; /#53$/d' | grep -oE '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}' | tail -n1)"
	fi
	if [ -z "$tmp_ip" ]; then
		tmp_ip="$(curl -sL --connect-timeout 3 "https://public1.114dns.com/resolve?domain=$domain&type=A" 2>/dev/null | grep -oE '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}')"
	fi
	echo -n "$tmp_ip"
}

resolve2ip6() {
	local domain="$1"
	local tmp_ip6
	tmp_ip6="$(nslookup "$domain" ns1.alidns.com 2>/dev/null | sed '/^Server/d; /#53$/d' | grep -oE '([0-9A-Fa-f]{0,4}:){2,7}[0-9A-Fa-f:]+' | tail -n1)"
	if [ -z "$tmp_ip6" ]; then
		tmp_ip6="$(nslookup "$domain" ns2.alidns.com 2>/dev/null | sed '/^Server/d; /#53$/d' | grep -oE '([0-9A-Fa-f]{0,4}:){2,7}[0-9A-Fa-f:]+' | tail -n1)"
	fi
	if [ -z "$tmp_ip6" ]; then
		tmp_ip6="$(nslookup "$domain" 2400:da00::6666 2>/dev/null | sed '/^Server/d; /#53$/d' | grep -oE '([0-9A-Fa-f]{0,4}:){2,7}[0-9A-Fa-f:]+' | tail -n1)"
	fi
	if [ -z "$tmp_ip6" ]; then
		tmp_ip6="$(curl -sL --connect-timeout 3 "https://public1.114dns.com/resolve?domain=$domain&type=AAAA" 2>/dev/null | grep -oE '([0-9A-Fa-f]{0,4}:){2,7}[0-9A-Fa-f:]+')"
	fi
	echo -n "$tmp_ip6"
}

urlencode() {
	local out=""
	for c in $(echo -n "$1" | od -An -tx1 | tr ' ' '\n' | while read b; do [ -n "$b" ] && echo "$b"; done); do
		case "$c" in
			[a-zA-Z0-9._~-]) out="${out}${c}" ;;
			*) out="${out}%$(printf '%02X' "0x${c}")" ;;
		esac
	done
	echo -n "$out"
}

send_request() {
	local args="AccessKeyId=${ak_id}&Action=$1&Format=json&$2&Version=2015-01-09"
	local hash
	hash="$(printf '%s' "GET&%2F&$(urlencode "$args")" | openssl dgst -sha1 -hmac "${ak_sec}&" -binary | openssl base64 | tr -d '\n')"
	hash="$(urlencode "$hash")"
	curl -sSL --connect-timeout 10 "http://alidns.aliyuncs.com/?${args}&Signature=${hash}"
}

get_recordid() {
	sed 's/RR/\n/g' | sed -n 's/.*RecordId[^0-9]*\([0-9]*\).*/\1\n/p' | sort -ru | sed '/^$/d'
}

check_aliddns() {
	echo "$DATE WAN-IP: ${ip}"
	if [ -z "$ip" ]; then
		echo "$DATE ERROR, cant get WAN-IP..."
		return 0
	fi
	current_ip="$(resolve2ip "$dm_real")"
	if [ -z "$current_ip" ]; then
		rrid=''
	fi
	echo "$DATE DOMAIN-IP: ${current_ip}"
	if [ "$ip" = "$current_ip" ]; then
		echo "$DATE IP dont need UPDATE..."
		return 0
	else
		echo "$DATE UPDATING..."
		ip6_escape="$(urlencode "$current_ip")"
		return 1
	fi
}

check_aliddns6() {
	echo "$DATE WAN6-IP: ${ip6}"
	if [ -z "$ip6" ]; then
		echo "$DATE ERROR, cant get WAN6-IP..."
		return 0
	fi
	current_ip6="$(resolve2ip6 "$dm_real")"
	echo "$DATE DOMAIN-IP6: ${current_ip6}"
	if [ -z "$current_ip6" ]; then
		rrid6=''
	fi
	if [ "$ip6" = "$current_ip6" ]; then
		echo "$DATE IPv6 dont need UPDATE..."
		return 0
	else
		echo "$DATE UPDATING AAAA..."
		return 1
	fi
}

do_ddns_record() {
	if uci_bool_by_name base clean; then
		query_recordid | get_recordid | while read -r rr; do
			echo "$DATE Clean record $dm_show: $rr"
			del_record "$rr" >/dev/null 2>&1
			timestamp="$(date -u '+%Y-%m-%dT%H%%3A%M%%3A%SZ')"
		done
		rrid=''
	fi
	if [ -z "$rrid" ]; then
		rrid="$(query_recordid | get_recordid)"
	fi
	if [ -z "$rrid" ]; then
		rrid="$(add_record | get_recordid)"
		echo "$DATE ADD record $rrid"
	else
		update_record "$rrid" >/dev/null 2>&1
		echo "$DATE UPDATE record $rrid"
	fi
	if [ -z "$rrid" ]; then
		echo "$DATE # ERROR, Please Check Config/Time"
	else
		uci set aliddns.base.record_id="$rrid"
		uci commit aliddns
		echo "$DATE # UPDATED($ip)"
	fi
}

do_ddns_record6() {
	if uci_bool_by_name base clean; then
		query_recordid6 | get_recordid | while read -r rr; do
			echo "$DATE Clean record $dm_show: $rr"
			del_record "$rr" >/dev/null 2>&1
			timestamp="$(date -u '+%Y-%m-%dT%H%%3A%M%%3A%SZ')"
		done
		rrid6=''
	fi
	if [ -z "$rrid6" ]; then
		rrid6="$(query_recordid6 | get_recordid)"
	fi
	if [ -z "$rrid6" ]; then
		rrid6="$(add_record6 | get_recordid)"
		echo "$DATE ADD record $rrid6"
	else
		update_record6 "$rrid6" >/dev/null 2>&1
		echo "$DATE UPDATE record $rrid6"
	fi
	if [ -z "$rrid6" ]; then
		echo "$DATE # ERROR, Please Check Config/Time"
	else
		uci set aliddns.base.record_id6="$rrid6"
		uci commit aliddns
		echo "$DATE # UPDATED($ip6)"
	fi
}

query_recordid() {
	send_request "DescribeSubDomainRecords" "SignatureMethod=HMAC-SHA1&SignatureNonce=${timestamp}&SignatureVersion=1.0&SubDomain=${dm_escape}&Timestamp=${timestamp}&Type=A"
}

query_recordid6() {
	send_request "DescribeSubDomainRecords" "SignatureMethod=HMAC-SHA1&SignatureNonce=${timestamp}&SignatureVersion=1.0&SubDomain=${dm_escape}&Timestamp=${timestamp}&Type=AAAA"
}

update_record() {
	send_request "UpdateDomainRecord" "RR=${sub_dm_escape}&RecordId=$1&SignatureMethod=HMAC-SHA1&SignatureNonce=${timestamp}&SignatureVersion=1.0&Timestamp=${timestamp}&Type=A&Value=${ip}"
}

add_record() {
	send_request "AddDomainRecord&DomainName=${main_dm}" "RR=${sub_dm_escape}&SignatureMethod=HMAC-SHA1&SignatureNonce=${timestamp}&SignatureVersion=1.0&Timestamp=${timestamp}&Type=A&Value=${ip}"
}

update_record6() {
	send_request "UpdateDomainRecord" "RR=${sub_dm_escape}&RecordId=$1&SignatureMethod=HMAC-SHA1&SignatureNonce=${timestamp}&SignatureVersion=1.0&Timestamp=${timestamp}&Type=AAAA&Value=${ip6_escape}"
}

add_record6() {
	send_request "AddDomainRecord&DomainName=${main_dm}" "RR=${sub_dm_escape}&SignatureMethod=HMAC-SHA1&SignatureNonce=${timestamp}&SignatureVersion=1.0&Timestamp=${timestamp}&Type=AAAA&Value=${ip6_escape}"
}

del_record() {
	send_request "DeleteDomainRecord" "RecordId=$1&SignatureMethod=HMAC-SHA1&SignatureNonce=${timestamp}&SignatureVersion=1.0&Timestamp=${timestamp}"
}

clean_log() {
	local lines
	lines="$(cat "$LOG_FILE" 2>/dev/null | wc -l)"
	if [ "$lines" -ge 240 ]; then
		rm -f "$LOG_FILE" && touch "$LOG_FILE"
		echo "$DATE Log Cleaned"
	fi
}

[ -x /usr/bin/openssl ] || {
	echo "Need openssl"
	exit 1
}

ipv4="$(uci_get_by_name base ipv4)"
ipv6="$(uci_get_by_name base ipv6)"
ak_id="$(uci_get_by_name base app_key)"
ak_sec="$(uci_get_by_name base app_secret)"
rrid="$(uci_get_by_name base record_id)"
rrid6="$(uci_get_by_name base record_id6)"
main_dm="$(uci_get_by_name base main_domain)"
sub_dm="$(uci_get_by_name base sub_domain)"

if [ "$sub_dm" = "@" ] || [ -z "$sub_dm" ]; then
	dm_real="$main_dm"
else
	dm_real="${sub_dm}.${main_dm}"
fi
dm_show="${sub_dm}.${main_dm}"
dm_escape="$(urlencode "${sub_dm}.${main_dm}")"
sub_dm_escape="$(urlencode "$sub_dm")"

iface="$(uci_get_by_name base interface)"
if [ "$iface" = "internet" ] || [ -z "$iface" ]; then
	ip="$(intelnetip)"
else
	ip="$(ubus call network.interface.$iface status 2>/dev/null | grep '"address"' | grep -oE '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}' | head -1)"
fi

DATE="$(date '+%Y-%m-%d %H:%M:%S')"
timestamp="$(date -u '+%Y-%m-%dT%H%%3A%M%%3A%SZ')"

if [ "$ipv4" = "1" ]; then
	check_aliddns || do_ddns_record
fi

iface6="$(uci_get_by_name base interface6)"
if [ "$iface6" = "internet" ] || [ -z "$iface6" ]; then
	ip6="$(intelnetip6)"
else
	ip6="$(ubus call network.interface.$iface6 status 2>/dev/null | grep '"address"' | grep -oE '([0-9A-Fa-f]{0,4}:){2,7}[0-9A-Fa-f:]+' | head -1)"
fi
ip6_escape="$(urlencode "$ip6")"

if [ "$ipv6" = "1" ]; then
	check_aliddns6 || do_ddns_record6
fi

clean_log
